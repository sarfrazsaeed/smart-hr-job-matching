/* SmartHire — React Dashboard Summary Widget */
const { useState: useState, useEffect: useEffect } = React;

function SummaryWidget() {
  const [stats, setStats] = useState({ candidates: 0, jobs: 0, topSkill: '—', avgExp: '0' });

  useEffect(() => {
    const candidates = JSON.parse(localStorage.getItem('candidates')) || [];
    const jobs = JSON.parse(localStorage.getItem('jobs')) || [];
    const allSkills = candidates.flatMap(c =>
      c.skills.toLowerCase().split(',').map(s => s.trim()).filter(Boolean)
    );
    const freq = {};
    allSkills.forEach(s => { freq[s] = (freq[s] || 0) + 1; });
    const topSkill = Object.keys(freq).sort((a, b) => freq[b] - freq[a])[0] || '—';
    const avgExp = candidates.length > 0
      ? (candidates.reduce((sum, c) => sum + parseFloat(c.experience || 0), 0) / candidates.length).toFixed(1)
      : '0';
    setStats({ candidates: candidates.length, jobs: jobs.length, topSkill, avgExp });
  }, []);

  return React.createElement('div', { className: 'card shadow border-0 mt-4' },
    React.createElement('div', { className: 'card-header bg-dark text-white py-3' },
      React.createElement('h5', { className: 'mb-0' },
        React.createElement('i', { className: 'bi bi-robot me-2' }),
        'React Live Summary'
      )
    ),
    React.createElement('div', { className: 'card-body' },
      React.createElement('div', { className: 'row g-3 text-center' },
        [
          { label: 'Total Candidates', value: stats.candidates, color: 'primary', icon: 'bi-people-fill' },
          { label: 'Total Jobs', value: stats.jobs, color: 'success', icon: 'bi-briefcase-fill' },
          { label: 'Top Skill', value: stats.topSkill, color: 'warning', icon: 'bi-star-fill' },
          { label: 'Avg Experience', value: stats.avgExp + ' yrs', color: 'info', icon: 'bi-clock-fill' },
        ].map(item =>
          React.createElement('div', { className: 'col-md-3 col-6', key: item.label },
            React.createElement('div', { className: `p-3 rounded bg-${item.color} bg-opacity-10 border border-${item.color} border-opacity-25` },
              React.createElement('i', { className: `bi ${item.icon} fs-3 text-${item.color} d-block mb-2` }),
              React.createElement('div', { className: 'fw-bold fs-4' }, item.value),
              React.createElement('div', { className: 'text-muted small' }, item.label)
            )
          )
        )
      )
    )
  );
}

const reactRoot = document.getElementById('react-summary-root');
if (reactRoot) {
  const root = ReactDOM.createRoot(reactRoot);
  root.render(React.createElement(SummaryWidget));
}