{
    "name": "smarthire-v2",
    "version": "2.0.0",
    "description": "SmartHire — AI-powered HR & Job Matching System. Phase 1-4 frontend complete.",
    "main": "index.html",
    "scripts": {
      "test": "jest --testEnvironment jsdom",
      "test:watch": "jest --watch --testEnvironment jsdom",
      "test:coverage": "jest --coverage --testEnvironment jsdom",
      "lint": "eslint --ext .js,.jsx . --ignore-pattern node_modules/ --no-error-on-unmatched-pattern",
      "format": "prettier --write ."
    },
    "jest": {
      "testEnvironment": "jsdom",
      "collectCoverageFrom": [
        "__tests__/**/*.{js,jsx}",
        "!**/node_modules/**"
      ],
      "testMatch": [
        "**/__tests__/**/*.test.{js,jsx}",
        "**/*.test.{js,jsx}",
        "**/*.spec.{js,jsx}"
      ],
  
      "transform": {
        "^.+\\.(js|jsx)$": "babel-jest"
      }
    },
    "keywords": [
      "hr", "job-matching", "react", "tailwind", "chart.js", "jest", "smarthire", "air-university"
    ],
    "author": "Sarfraz Saeed <sarfraz@au.edu.pk> (https://github.com/sarfrazsaeed)",
    "license": "MIT",
    "devDependencies": {
      "@babel/core": "^7.23.0",
      "@babel/preset-env": "^7.23.0",
      "@babel/preset-react": "^7.22.15",
      "@testing-library/jest-dom": "^6.1.4",
      "@testing-library/react": "^14.0.0",
      "@testing-library/user-event": "^14.5.1",
      "babel-jest": "^29.7.0",
      "eslint": "^8.52.0",
      "jest": "^29.7.0",
      "jest-axe": "^8.0.0",
      "jest-environment-jsdom": "^29.7.0",
      "prettier": "^3.0.3"
    },
    "engines": {
      "node": ">=18.0.0"
    }
  }